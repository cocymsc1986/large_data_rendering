{
  "name": "data-source",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone mock data source for large-dataset rendering experiments (time series, streaming, bulk dump)",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "generate:dump": "tsx scripts/generate-dump.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
